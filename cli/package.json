{
  "name": "gitmesh-agents",
  "version": "0.2.7",
  "description": "GitMesh Agents CLI — orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "gitmesh-agents": "./dist/index.js"
  },
  "keywords": [
    "gitmesh-agents",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LF-Decentralized-Trust-labs/gitmesh.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/LF-Decentralized-Trust-labs/gitmesh",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@gitmesh/adapter-claude-local": "workspace:*",
    "@gitmesh/adapter-codex-local": "workspace:*",
    "@gitmesh/adapter-cursor-local": "workspace:*",
    "@gitmesh/adapter-opencode-local": "workspace:*",
    "@gitmesh/adapter-pi-local": "workspace:*",
    "@gitmesh/adapter-gateway": "workspace:*",
    "@gitmesh/adapter-sdk": "workspace:*",
    "@gitmesh/data": "workspace:*",
    "@gitmesh/server": "workspace:*",
    "@gitmesh/core": "workspace:*",
    "drizzle-orm": "0.45.2",
    "dotenv": "^17.0.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
